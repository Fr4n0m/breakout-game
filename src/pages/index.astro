---
import DifficultyMenu from "../components/DifficultyMenu.astro";
import "../styles/game-page.css";
---

<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Breakout con JS</title>
    <link rel="icon" type="image/jpg" href="/favicon.png" />
</head>
<body>
    <div class="game-shell">
        <div class="game-stage">
            <canvas id="game-canvas" width="448" height="400"></canvas>
            <DifficultyMenu />
        </div>
    </div>

    <img hidden id="sprite" src="/Breakout_Tile_Free.png" alt="Breakout sprite" loading="eager" decoding="sync">

    <script>
        import { setupDifficultyMenu } from "../scripts/ui/difficultyMenu";

        setupDifficultyMenu();
    </script>
</body>
</html>
