---
import DifficultyMenu from "../components/DifficultyMenu.astro";
import "../styles/game-page.css";
---

<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Breakout with JS</title>
    <link rel="icon" type="image/jpg" href="/favicon.png" />
    <link rel="preload" href="/fonts/press-start-2p-latin-400-normal.woff2" as="font" type="font/woff2" crossorigin>
</head>
<body>
    <div class="game-shell">
        <div class="game-stage">
            <canvas id="game-canvas" width="448" height="400"></canvas>
            <DifficultyMenu />
        </div>
    </div>
    <p class="site-credit">
        Built by Fr4n0m
        <a href="https://codebyfran.es" target="_blank" rel="noopener noreferrer">codebyfran.es</a>
    </p>
    <p class="site-contrib">
        PRs welcome here
        <a href="https://github.com/Fr4n0m/breakout-game" target="_blank" rel="noopener noreferrer">github</a>
    </p>

    <img hidden id="sprite" src="/Breakout_Tile_Free.png" alt="Breakout sprite" loading="eager" decoding="sync">

    <script>
        import { setupDifficultyMenu } from "../scripts/ui/difficultyMenu";

        setupDifficultyMenu();
    </script>
</body>
</html>
